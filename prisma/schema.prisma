generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STORE_OWNER
  BRAND
  RETAILER
  DESIGNER
  CONSUMER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductType {
  PHYSICAL
  DIGITAL
  CUSTOM
}

enum LicenseType {
  PERSONAL
  COMMERCIAL
}

enum OrderStatus {
  PENDING
  PAYMENT_PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum CampaignChannel {
  WHATSAPP
  EMAIL
  SMS
  SOCIAL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum CRMTag {
  ABANDONED_CART
  REPEAT_BUYER
  HIGH_SPENDER
  NEWSLETTER
}

model User {
  id                 String               @id @default(cuid())
  name               String?
  email              String               @unique
  passwordHash       String?
  image              String?
  phone              String?              @unique
  phoneVerifiedAt    DateTime?
  emailVerified      DateTime?
  role               Role                 @default(CONSUMER)
  isActive           Boolean              @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  storeOwnerProfile  StoreOwnerProfile?
  brandProfile       BrandProfile?
  retailerProfile    RetailerProfile?
  designerProfile    DesignerProfile?

  products           Product[]            @relation("SellerProducts")
  carts              Cart[]
  orders             Order[]              @relation("CustomerOrders")
  wishlists          Wishlist[]

  affiliateLinks     AffiliateLink[]      @relation("AffiliateOwner")
  referralsMade      Referral[]           @relation("ReferrerUser")
  referralsReceived  Referral[]           @relation("ReferredUser")
  loyaltyWallet      LoyaltyWallet?

  sentMessages       Message[]            @relation("MessageSender")
  messageThreads     MessageThreadMember[]

  campaignsCreated   WhatsAppCampaign[]   @relation("CampaignCreator")
  crmContact         CRMContact?
}

model StoreOwnerProfile {
  id                 String          @id @default(cuid())
  userId             String          @unique
  storeName          String
  slug               String          @unique
  gstRegistered      Boolean         @default(false)
  gstNumber          String?
  businessAddress    String?
  approvalStatus     ApprovalStatus  @default(PENDING)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrandProfile {
  id                 String          @id @default(cuid())
  userId             String          @unique
  brandName          String
  slug               String          @unique
  website            String?
  description        String?
  approvalStatus     ApprovalStatus  @default(PENDING)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RetailerProfile {
  id                 String          @id @default(cuid())
  userId             String          @unique
  businessName       String
  storeCount         Int             @default(1)
  approvalStatus     ApprovalStatus  @default(PENDING)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DesignerProfile {
  id                 String          @id @default(cuid())
  userId             String          @unique
  displayName        String
  portfolioUrl       String?
  bio                String?
  approvalStatus     ApprovalStatus  @default(PENDING)
  commissionRate     Decimal         @db.Decimal(5, 2)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  customDesigns      CustomDesign[]
}

model Category {
  id                 String          @id @default(cuid())
  name               String
  slug               String          @unique
  parentId           String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  parent             Category?       @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children           Category[]      @relation("CategoryHierarchy")
  products           Product[]

  @@index([parentId])
}

model FabricOption {
  id                 String          @id @default(cuid())
  name               String          @unique
  hexCode            String?
  products           Product[]
}

model ColorOption {
  id                 String          @id @default(cuid())
  name               String          @unique
  hexCode            String
  products           Product[]
  variants           ProductVariant[]
}

model SizeOption {
  id                 String          @id @default(cuid())
  name               String          @unique
  sortOrder          Int             @default(0)
  variants           ProductVariant[]
}

model Product {
  id                 String            @id @default(cuid())
  sellerId           String
  categoryId         String
  fabricOptionId     String?
  colorOptionId      String?
  name               String
  slug               String            @unique
  description        String
  productType        ProductType       @default(PHYSICAL)
  basePrice          Decimal           @db.Decimal(12, 2)
  compareAtPrice     Decimal?          @db.Decimal(12, 2)
  sku                String?
  isPublished        Boolean           @default(false)
  approvalStatus     ApprovalStatus    @default(PENDING)
  isCustomizable     Boolean           @default(false)
  coverImageUrl      String?
  mediaUrls          String[]
  seoTitle           String?
  seoDescription     String?
  seoKeywords        String[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  seller             User              @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  category           Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  fabricOption       FabricOption?     @relation(fields: [fabricOptionId], references: [id], onDelete: SetNull)
  colorOption        ColorOption?      @relation(fields: [colorOptionId], references: [id], onDelete: SetNull)

  variants           ProductVariant[]
  inventory          Inventory?
  orderItems         OrderItem[]
  cartItems          CartItem[]
  wishlists          Wishlist[]
  trendAnalytics     TrendAnalytics[]
  seoSuggestions     SeoSuggestion[]
  quoteRequests      QuoteRequest[]

  @@index([sellerId, approvalStatus])
  @@index([categoryId])
  @@index([name])
}

model ProductVariant {
  id                 String            @id @default(cuid())
  productId          String
  sizeOptionId       String?
  colorOptionId      String?
  fabricName         String?
  sku                String?           @unique
  price              Decimal           @db.Decimal(12, 2)
  stock              Int               @default(0)
  imageUrl           String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  product            Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  sizeOption         SizeOption?       @relation(fields: [sizeOptionId], references: [id], onDelete: SetNull)
  colorOption        ColorOption?      @relation(fields: [colorOptionId], references: [id], onDelete: SetNull)
  orderItems         OrderItem[]
  cartItems          CartItem[]

  @@index([productId])
}

model Inventory {
  id                 String            @id @default(cuid())
  productId          String            @unique
  totalStock         Int               @default(0)
  reservedStock      Int               @default(0)
  reorderLevel       Int               @default(5)
  updatedAt          DateTime          @updatedAt

  product            Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Cart {
  id                 String            @id @default(cuid())
  userId             String?
  guestToken         String?           @unique
  couponId           String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user               User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  coupon             Coupon?           @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items              CartItem[]

  @@index([userId])
}

model CartItem {
  id                 String            @id @default(cuid())
  cartId             String
  productId          String
  productVariantId   String?
  quantity           Int               @default(1)
  customPreviewUrl   String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  cart               Cart              @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product            Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant     ProductVariant?   @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, productVariantId])
}

model Wishlist {
  id                 String            @id @default(cuid())
  userId             String
  productId          String
  createdAt          DateTime          @default(now())

  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  product            Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Coupon {
  id                 String            @id @default(cuid())
  code               String            @unique
  type               CouponType
  value              Decimal           @db.Decimal(10, 2)
  minOrderValue      Decimal?          @db.Decimal(10, 2)
  maxDiscount        Decimal?          @db.Decimal(10, 2)
  usageLimit         Int?
  usedCount          Int               @default(0)
  startsAt           DateTime?
  endsAt             DateTime?
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  carts              Cart[]
  orders             Order[]
}

model Order {
  id                 String            @id @default(cuid())
  orderNumber        String            @unique
  customerId         String
  couponId           String?
  status             OrderStatus       @default(PENDING)
  subtotalAmount     Decimal           @db.Decimal(12, 2)
  discountAmount     Decimal           @db.Decimal(12, 2) @default(0)
  taxAmount          Decimal           @db.Decimal(12, 2) @default(0)
  shippingAmount     Decimal           @db.Decimal(12, 2) @default(0)
  totalAmount        Decimal           @db.Decimal(12, 2)
  currency           String            @default("INR")
  shippingAddress    Json
  billingAddress     Json?
  invoiceUrl         String?
  placedAt           DateTime          @default(now())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  customer           User              @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)
  coupon             Coupon?           @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  payments           Payment[]

  @@index([customerId, status])
}

model OrderItem {
  id                 String            @id @default(cuid())
  orderId            String
  productId          String
  productVariantId   String?
  quantity           Int               @default(1)
  unitPrice          Decimal           @db.Decimal(12, 2)
  lineTotal          Decimal           @db.Decimal(12, 2)
  licenseType        LicenseType?
  downloadableUrl    String?
  customDesignId     String?

  order              Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  productVariant     ProductVariant?   @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  customDesign       CustomDesign?     @relation(fields: [customDesignId], references: [id], onDelete: SetNull)
}

model Payment {
  id                 String            @id @default(cuid())
  orderId            String
  provider           String            @default("stripe")
  providerPaymentId  String?
  providerSessionId  String?
  status             PaymentStatus     @default(PENDING)
  amount             Decimal           @db.Decimal(12, 2)
  currency           String            @default("INR")
  paidAt             DateTime?
  rawResponse        Json?
  createdAt          DateTime          @default(now())

  order              Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([providerPaymentId])
}

model CustomDesign {
  id                 String                @id @default(cuid())
  designerProfileId  String
  productId          String?
  title              String
  slug               String                @unique
  description        String?
  isPublished        Boolean               @default(false)
  price              Decimal               @db.Decimal(12, 2)
  licenseType        LicenseType           @default(PERSONAL)
  previewImageUrl    String?
  sourceJsonUrl      String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  designerProfile    DesignerProfile       @relation(fields: [designerProfileId], references: [id], onDelete: Cascade)
  product            Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  layers             DesignLayer[]
  assets             DesignAsset[]
  orderItems         OrderItem[]
  mockupRenders      MockupRender[]
  quoteRequests      QuoteRequest[]
}

model DesignLayer {
  id                 String                @id @default(cuid())
  customDesignId     String
  layerType          String
  zIndex             Int
  transformJson      Json
  styleJson          Json?
  createdAt          DateTime              @default(now())

  customDesign       CustomDesign          @relation(fields: [customDesignId], references: [id], onDelete: Cascade)
}

model DesignAsset {
  id                 String                @id @default(cuid())
  customDesignId     String
  assetType          String
  url                String
  metadata           Json?
  createdAt          DateTime              @default(now())

  customDesign       CustomDesign          @relation(fields: [customDesignId], references: [id], onDelete: Cascade)
}

model MockupRender {
  id                 String                @id @default(cuid())
  customDesignId     String
  templateName       String
  outputImageUrl     String
  outputJsonUrl      String?
  createdAt          DateTime              @default(now())

  customDesign       CustomDesign          @relation(fields: [customDesignId], references: [id], onDelete: Cascade)
}

model QuoteRequest {
  id                 String                @id @default(cuid())
  requesterId        String
  productId          String?
  customDesignId     String?
  notes              String?
  status             String                @default("OPEN")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  requester          User                  @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  product            Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  customDesign       CustomDesign?         @relation(fields: [customDesignId], references: [id], onDelete: SetNull)
  offers             QuoteOffer[]
}

model QuoteOffer {
  id                 String                @id @default(cuid())
  quoteRequestId     String
  sellerId           String
  offeredPrice       Decimal               @db.Decimal(12, 2)
  estimatedDays      Int?
  message            String?
  createdAt          DateTime              @default(now())

  quoteRequest       QuoteRequest          @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  seller             User                  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model MessageThread {
  id                 String                @id @default(cuid())
  subject            String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  members            MessageThreadMember[]
  messages           Message[]
}

model MessageThreadMember {
  id                 String                @id @default(cuid())
  threadId           String
  userId             String
  createdAt          DateTime              @default(now())

  thread             MessageThread         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
}

model Message {
  id                 String                @id @default(cuid())
  threadId           String
  senderId           String
  body               String
  createdAt          DateTime              @default(now())

  thread             MessageThread         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender             User                  @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
}

model TrendAnalytics {
  id                 String                @id @default(cuid())
  productId          String?
  categoryId         String?
  metricDate         DateTime
  impressions        Int                   @default(0)
  clicks             Int                   @default(0)
  addsToCart         Int                   @default(0)
  purchases          Int                   @default(0)
  trendScore         Decimal               @db.Decimal(8, 2)
  colorInsights      Json?
  fabricInsights     Json?
  createdAt          DateTime              @default(now())

  product            Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  category           Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([metricDate])
}

model SeoSuggestion {
  id                 String                @id @default(cuid())
  productId          String
  suggestedTitle     String
  suggestedDesc      String
  suggestedKeywords  String[]
  generatedBy        String                @default("ai")
  createdAt          DateTime              @default(now())

  product            Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SocialCampaignDraft {
  id                 String                @id @default(cuid())
  ownerId            String
  title              String
  objective          String?
  channel            CampaignChannel
  caption            String
  hashtags           String[]
  adCopy             String?
  creativeUrl        String?
  calendarDate       DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  owner              User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model WhatsAppCampaign {
  id                 String                @id @default(cuid())
  createdById        String
  name               String
  templateName       String
  status             CampaignStatus        @default(DRAFT)
  scheduledAt        DateTime?
  sentAt             DateTime?
  targetTags         CRMTag[]
  payload            Json
  provider           String                @default("meta")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  createdBy          User                  @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: Cascade)
}

model CRMContact {
  id                 String                @id @default(cuid())
  userId             String?               @unique
  fullName           String
  email              String?
  phone              String?
  tags               CRMTag[]
  totalOrders        Int                   @default(0)
  totalSpent         Decimal               @db.Decimal(12, 2) @default(0)
  optedInWhatsApp    Boolean               @default(false)
  lastActiveAt       DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  user               User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AccountingReport {
  id                 String                @id @default(cuid())
  ownerId            String
  periodStart        DateTime
  periodEnd          DateTime
  grossRevenue       Decimal               @db.Decimal(12, 2)
  netRevenue         Decimal               @db.Decimal(12, 2)
  expenses           Decimal               @db.Decimal(12, 2)
  taxCollected       Decimal               @db.Decimal(12, 2)
  forecastPnl        Decimal?              @db.Decimal(12, 2)
  csvUrl             String?
  pdfUrl             String?
  createdAt          DateTime              @default(now())

  owner              User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model AffiliateLink {
  id                 String                @id @default(cuid())
  ownerId            String
  code               String                @unique
  destinationUrl     String
  clicks             Int                   @default(0)
  conversions        Int                   @default(0)
  commissionEarned   Decimal               @db.Decimal(12, 2) @default(0)
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())

  owner              User                  @relation("AffiliateOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  referrals          Referral[]
}

model Referral {
  id                 String                @id @default(cuid())
  affiliateLinkId    String?
  referrerId         String
  referredUserId     String
  rewardGranted      Boolean               @default(false)
  createdAt          DateTime              @default(now())

  affiliateLink      AffiliateLink?        @relation(fields: [affiliateLinkId], references: [id], onDelete: SetNull)
  referrer           User                  @relation("ReferrerUser", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser       User                  @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredUserId])
}

model LoyaltyWallet {
  id                 String                @id @default(cuid())
  userId             String                @unique
  pointsBalance      Int                   @default(0)
  walletCredit       Decimal               @db.Decimal(10, 2) @default(0)
  tierLabel          String                @default("Classic")
  updatedAt          DateTime              @updatedAt

  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id                 String                @id @default(cuid())
  tier               SubscriptionTier      @unique
  name               String
  priceMonthly       Decimal               @db.Decimal(10, 2)
  priceYearly        Decimal?              @db.Decimal(10, 2)
  stripePriceId      String?
  featureFlags       Json
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}
